# ─────────────────────────────────────────────────────────────
# speak-to-llm — environment variable reference
# Copy to .env (repo root) and adjust values for your setup.
# VITE_* vars are also needed in frontend/.env.local for Vite.
# ─────────────────────────────────────────────────────────────

# ── Frontend (Vite) ───────────────────────────────────────────
# WebSocket URL the browser connects to (proxied by Vite in dev)
VITE_WS_URL=ws://localhost:8000/ws/audio

# Browser tab / app title
VITE_APP_TITLE=speak-to-llm

# ── LM Studio ────────────────────────────────────────────────
# Base URL of the locally-running LM Studio OpenAI-compat server
LM_STUDIO_BASE_URL=http://localhost:1234/v1

# Model identifier as reported by LM Studio (e.g. loaded model name)
LM_STUDIO_MODEL=local-model

# ── Whisper ───────────────────────────────────────────────────
# openai-whisper model size: tiny | base | small | medium | large
WHISPER_MODEL=base

# ── Backend server ────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins (Vite dev server default)
CORS_ORIGINS=http://localhost:5173

# ── Logging ──────────────────────────────────────────────────
# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
